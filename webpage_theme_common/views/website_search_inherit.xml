<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_search_box_inherit" inherit_id="website.website_search_box">
        <xpath expr="//input[@name='search']" position="attributes">
            <attribute name="t-att-placeholder">
                website and website.search_placeholder and website.search_placeholder_effect == 'none'
                and website.search_placeholder.split('\n')[0]
                or 'Search...'
            </attribute>
            <attribute name="class" add="tp-search-input"/>
            <attribute name="t-att-class">
                website and website.search_placeholder_effect != 'none'
                and 'tp-search-input tp-hide-native-placeholder'
                or 'tp-search-input'
            </attribute>

        </xpath>

        <xpath expr="//input[@name='search']" position="after">

            <t t-if="website
                     and website.search_placeholder
                     and website.search_placeholder_effect != 'none'">

                <t t-foreach="website.search_placeholder.split('\n')"
                   t-as="frase"
                   t-foreach-index="i">

                    <span t-att-class="'tp-fake-placeholder ' +
                                       website.search_placeholder_effect +
                                       ' ' +
                                       (i == 0 and 'active' or '')"

                          t-att-style="'--anim-duration: %ss'
                                       % (website.search_placeholder_duration or 2)">

                        <t t-esc="frase"/>

                    </span>

                </t>

            </t>

        </xpath>

    </template>
</odoo>