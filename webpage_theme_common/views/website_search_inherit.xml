<odoo>

    <template id="website_search_box_inherit"
              inherit_id="website.website_search_box">

        <!-- eliminar placeholder original -->
        <xpath expr="//input[@name='search']"
               position="attributes">

            <attribute name="t-att-placeholder">''</attribute>

            <attribute name="class" add="tp-search-input"/>

        </xpath>

        <!-- texto animado -->
        <xpath expr="//input[@name='search']"
               position="after">

            <span t-if="website.search_placeholder"
                  t-att-class="'tp-fake-placeholder ' + (website.search_placeholder_effect or '')">

                <t t-esc="website.search_placeholder"/>

            </span>

        </xpath>

    </template>

</odoo>