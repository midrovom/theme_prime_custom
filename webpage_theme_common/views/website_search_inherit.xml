<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="website_search_box_inherit"
              inherit_id="website.website_search_box">

        <!-- agregar wrapper -->
        <xpath expr="//input[@name='search']" position="before">
            <div class="tp-search-wrapper"/>
        </xpath>

        <xpath expr="//input[@name='search']" position="move">
            <xpath expr="//div[@class='tp-search-wrapper']" position="inside"/>
        </xpath>

        <!-- quitar placeholder original -->
        <xpath expr="//input[@name='search']" position="attributes">
            <attribute name="placeholder"></attribute>
            <attribute name="class" add="tp-search-input"/>
        </xpath>

        <!-- frases -->
        <xpath expr="//input[@name='search']" position="after">
            <t t-if="website and website.search_placeholder">

                <t t-foreach="website.search_placeholder.splitlines()"
                   t-as="frase">

                    <span class="tp-fake-placeholder"
                          t-att-style="'--anim-duration:%ss' % (website.search_placeholder_duration or 5)">

                        <t t-esc="frase"/>

                    </span>

                </t>

            </t>
        </xpath>

    </template>

</odoo>