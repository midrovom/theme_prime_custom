<odoo>
    <template id="website_search_box_inherit" inherit_id="website.website_search_box">
        <xpath expr="//input[@name='search']" position="attributes">
            <attribute name="t-att-placeholder">website.search_placeholder or 'Buscar...'</attribute>
        </xpath>

        <!-- Agregas un span con animación justo después del input -->
        <xpath expr="//input[@name='search']" position="after">
            <span class="search-text" t-att-class="website.search_placeholder_effect">
                <t t-esc="website.search_placeholder or 'Buscar...'"/>
            </span>
        </xpath>
    </template>
</odoo>
