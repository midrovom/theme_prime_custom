<odoo>
    <data>

        <record id="website_location_form_view" model="ir.ui.view">
            <field name="name">website.location.form.view</field>
            <field name="model">website.location</field>
            <field name="arch" type="xml">
                <form string="Website Location View">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="city"/>
                            <field name="address"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="website_location_list_view" model="ir.ui.view">
            <field name="name">website.location.list.view</field>
            <field name="model">website.location</field>
            <field name="arch" type="xml">
                <list string="Website Location">
                    <field name="name"/>
                    <field name="city"/>
                    <field name="address"/>
                    <field name="latitude"/>
                    <field name="longitude"/>
                </list>
            </field>
        </record>

        <record id="website_location_action_views" model="ir.actions.act_window">
            <field name="name">Localidades</field>
            <field name="res_model">website.location</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'list_view_ref':'webpage_theme_common.website_location_list_view'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Define una nueva localidad
                </p>
                <p>
                    Las localidades representan sedes, tiendas o ubicaciones relacionadas con tu sitio web.
                </p>
            </field>
        </record>

        <!-- Menú principal autocerrado -->
        <menuitem id="menu_locations"
                  name="Localidades"
                  parent="website_sale.menu_ecommerce"
                  sequence="4"/>

        <!-- Submenú con acción -->
        <menuitem id="menu_locations_custom"
                  name="Localidad"
                  action="webpage_theme_common.website_location_action_views"
                  parent="menu_locations"
                  sequence="1"/>

    </data>
</odoo>
