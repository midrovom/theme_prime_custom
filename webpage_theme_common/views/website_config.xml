<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_website_form_inherit_search_placeholder" model="ir.ui.view">
        <field name="name">website.form.inherit.search.placeholder</field>
        <field name="model">website</field>
        <field name="inherit_id" ref="website.view_website_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Configuración del buscador">
                    <field name="search_placeholder"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- vista tree para listar sitios web -->
    <record id="view_website_tree_custom" model="ir.ui.view">
        <field name="name">website.tree.custom</field>
        <field name="model">website</field>
        <field name="arch" type="xml">
            <tree string="Sitios Web">
                <field name="name"/>
                <field name="domain"/>
                <field name="search_placeholder"/>
            </tree>
        </field>
    </record>

    <!-- Acción que abre la lista y formulario de sitios web -->
    <record id="action_website_search_placeholder" model="ir.actions.act_window">
        <field name="name">Configuración del buscador</field>
        <field name="res_model">website</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
        <field name="view_id" ref="view_website_tree_custom"/>
    </record>

    <!-- Submenú debajo de Localidades -->
    <menuitem id="menu_search_placeholder"
              name="Buscador"
              parent="menu_locations"
              action="action_website_search_placeholder"
              sequence="2"/>
</odoo>

