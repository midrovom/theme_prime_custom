<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!--        Loan Request Action-->
        <record id="loan_request_action" model="ir.actions.act_window">
            <field name="name">Solicitud de plan</field>
            <field name="res_model">loan.request</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!--        Loan Request Tree View-->
        <record id="loan_request_view_list" model="ir.ui.view">
            <field name="name">loan.request.view.list</field>
            <field name="model">loan.request</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Loan Request">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="loan_amount"/>
                    <field name="interest_rate"/>
                    <field name="date"/>
                    <field name="tenure"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!--        Sequence Number Loan Request Records-->
        <record id="increment_loan_reference" model="ir.sequence">
            <field name="name">Loan Reference</field>
            <field name="code">increment_loan_ref</field>
            <field name="prefix">LOAN</field>
            <field name="padding">3</field>
        </record>

        <!--        Loan Request Form View-->
        <record id="loan_request_view_form" model="ir.ui.view">
            <field name="name">loan.request.view.form</field>
            <field name="model">loan.request</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Loan Request" delete="false">
                    <header>
                        <div class="alert alert-info" role="alert"
                            style="height: 40px; margin-bottom:0px;"
                            invisible="state not in ['waiting for approval']"
                            groups="advanced_loan_management.loan_management_group_user">
                            Waiting for approval from the manager
                        </div>
                        <div class="alert alert-info" role="alert"
                            style="height: 40px; margin-bottom:0px;"
                            invisible="state not in ['approved']">
                            Debe ingresar el EMEI del dispositivo
                        </div>

                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,confirmed,approved"/>
                        <button name="action_loan_request" class="oe_highlight"
                                string="Confirm"
                                type="object"
                                invisible="state != 'draft'"/>
                        <button name="action_compute_repayment" class="oe_highlight"
                                string="Calcular pagos"
                                type="object"
                                invisible="state != 'confirmed'"/>
                        <button name="action_request_for_loan" class="oe_highlight"
                                string="Solicitud"
                                type="object"
                                invisible="state != 'confirmed'"/>
                        <button name="action_loan_approved" class="oe_highlight"
                                string="Aprobar"
                                type="object"
                                groups="advanced_loan_management.loan_management_group_manager"
                                invisible="state != 'waiting for approval'"/>
                        <button name="action_loan_rejected" class="oe_highlight"
                                string="Rechazar"
                                type="object"
                                groups="advanced_loan_management.loan_management_group_manager"
                                invisible="state != 'waiting for approval'"/>
                        <button name="action_disburse_loan" class="oe_highlight"
                                string="Otorgar Plan"
                                type="object"
                                invisible="state != 'approved'"/>
                        <button name="action_close_loan" class="oe_highlight"
                                string="Cerrar"
                                type="object"
                                invisible="state != 'disbursed'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" style="width: 50%;" placeholder="Loan Type"/>
                            </h1>
                        </div>
                    
                        <group>
                            <group>
                                <field name="partner_id" readonly="state != 'draft'"/>
                                <field name="loan_type_id"
                                    options="{'no_open':True, 'no_create': True}"
                                    readonly="state != 'draft'"/>
                                <field name="product_id" 
                                    options="{'no_open':True, 'no_create': True}"
                                    readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <div class="product-image-container">
                                    <field name="product_image" widget="image" readonly="1"/>
                                </div>
                            </group>
                            <group>
                                <field name="suggested_loan_amount"/>
                                <field name="loan_amount"/>
                                <field name="interest_rate" widget="percentage"/>
                                <field name="entry_rate" widget="percentage" readonly="state != 'draft'"/>
                                <field name="entry_amount"/>
                                <field name="loan_amount_total"/>
                                <field name="company_id"/>
                            </group>
                            <group>
                                <field name="disbursal_amount"/>
                                <field name="tenure"/>
                                <field name="payment_value"/>
                                <field name="currency_id" readonly="state != 'draft'"/>
                                <field name="date_concesion"/>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="imei" invisible="state not in ['approved','disbursed','closed']"
                                    readonly="state != 'approved'"/>
                                <field name="request" invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Calendario de pagos" invisible="state == 'draft'">
                                <field name="repayment_lines_ids" readonly="1">
                                    <list string="tree" create="false">
                                        <field name="name"/>
                                        <field name="date"/>
                                        <field name="amount" invisible="1"/>
                                        <field name="interest_amount" invisible="1"/>
                                        <field name="total_amount"/>
                                        <field name="state"
                                            column_invisible="parent.state != 'disbursed'"
                                            widget="badge"
                                            optional="show"
                                            decoration-danger="state == 'unpaid'"
                                            decoration-info="state == 'invoiced'"
                                            decoration-success="state == 'paid'"
                                            decoration-warning="state == 'disbursed'"/>
                                        <field name="invoice" invisible="1"/>
                                        <button name="action_pay_emi"
                                                class="oe_highlight"
                                                string="Pagar"
                                                type="object"
                                                invisible="invoice or state == 'paid' or parent.state != 'disbursed'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Documentos">
                                <group>
                                    <field name="documents_ids" widget="many2many_tags"/>
                                    <field name="img_attachment_ids" widget="many2many_binary"/>
                                </group>
                            </page>
                            <page string="Loan rejection" invisible="state != 'rejected'">
                                <field name="reject_reason" readonly="1"/>
                            </page>
                            <page string="Contabilidad" invisible="True">
                                <group>
                                    <group>
                                        <field name="journal_id" readonly="state == 'disbursed'"/>
                                    </group>
                                    <group>
                                        <field name="debit_account_id" readonly="state == 'disbursed'"/>
                                        <field name="credit_account_id" readonly="state == 'disbursed'"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
</odoo>
