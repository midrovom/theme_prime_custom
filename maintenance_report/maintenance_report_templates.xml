<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_request">
        <t t-call="web.basic_layout">
            <div class="page">
                <h2 style="text-align:center;">Maintenance Request Report</h2>
                <t t-foreach="docs" t-as="request">
                    <div style="margin-top:20px; border:1px solid #000; padding:10px; border-radius:6px;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td><strong>Request Name:</strong></td>
                                <td t-out="request.name"/>
                            </tr>
                            <tr>
                                <td><strong>Equipment:</strong></td>
                                <td t-out="request.equipment_id.name"/>
                            </tr>
                            <tr>
                                <td><strong>Category:</strong></td>
                                <td t-out="request.category_id.name"/>
                            </tr>
                            <tr>
                                <td><strong>Responsible:</strong></td>
                                <td t-out="request.user_id.name"/>
                            </tr>
                            <tr>
                                <td><strong>Scheduled Date:</strong></td>
                                <td t-out="request.schedule_date"/>
                            </tr>
                            <tr>
                                <td><strong>Status:</strong></td>
                                <td t-out="request.stage_id.name"/>
                            </tr>
                            <tr>
                                <td><strong>Description:</strong></td>
                                <td t-out="request.description"/>
                            </tr>
                        </table>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>

