<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="maintenance_equipment_view_form_inherit_hr" model="ir.ui.view">
        <field name="name">maintenance.equipment.view.form.inherit.hr</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="entregado_por_id" widget="many2one_avatar_employee" domain="[('department_id.responsable_entrega_equipo','=',True)]"/>
            </xpath>
        </field>
    </record>

    <record id="view_employee_form_inherit_attachment" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.attachment</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
                <!-- Localiza el botón de adjuntar en el chatter -->
            <xpath expr="//button[contains(@class,'o-mail-Chatter-attachFiles')]" position="attributes">
                    <!-- Solo mostrar si el usuario NO está en el grupo de solo lectura -->
                <attribute name="groups">!maintenance_report.group_attachment_hr_readonly</attribute>
            </xpath>
        </field>
    </record>


</odoo>
