<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="maintenance_equipment_view_form_inherit_hr" model="ir.ui.view">
        <field name="name">maintenance.equipment.view.form.inherit.hr</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="replace">
                <field name="equipment_assign_to" widget="radio"/>
                <field name="employee_id" string="Empleado que recibe"
                    invisible="equipment_assign_to == 'department' or not equipment_assign_to"
                    widget="many2one_avatar_employee"/>
                <field name="department_id" string="Department"
                    invisible="equipment_assign_to == 'employee' or not equipment_assign_to"/>
                <field name="entregado_por_id" string="Responsable de Entrega"
                    widget="many2one_avatar_employee"/>
            </xpath>
        </field>
    </record>

</odoo>

