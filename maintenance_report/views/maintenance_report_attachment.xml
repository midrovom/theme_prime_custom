<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="attachment_card_readonly" inherit_id="mail.attachment_card">
        <!-- Botón eliminar -->
        <xpath expr="//button[contains(@class,'o-mail-AttachmentCard-unlink')]" position="attributes">
            <attribute name="groups">base.group_user,!maintenance_report.group_attachment_readonly</attribute>
        </xpath>

        <!-- Botón descargar -->
        <xpath expr="//button[contains(@title,'Descargar')]" position="attributes">
            <attribute name="groups">base.group_user,!maintenance_report.group_attachment_readonly</attribute>
        </xpath>
    </template>
</odoo>
