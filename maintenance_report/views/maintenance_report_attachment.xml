<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="maintenance_report_attachment_inherit" inherit_id="mail.AttachmentBoxView" name="Restricción de adjuntos en chatter">
        <xpath expr="//button[contains(@class,'o-mail-AttachmentCard-unlink')]" position="replace">
            <t t-if="user_has_group('maintenance_report.group_attachment_admin')">
                <button class="o-mail-AttachmentCard-unlink btn" title="Eliminar">
                    <i class="fa fa-trash" role="img" aria-label="Eliminar"/>
                </button>
            </t>
        </xpath>
        <xpath expr="//button[contains(@class,'btn-link') and contains(.,'Adjuntar archivos')]" position="replace">
            <t t-if="user_has_group('maintenance_report.group_attachment_admin')">
                <button class="btn btn-link" type="button">
                    <i class="fa fa-plus-square"/> Adjuntar archivos
                </button>
            </t>
        </xpath>
    </template>

</odoo>

