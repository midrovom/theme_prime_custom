<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_hr_employee_form_inherit_documents" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.documents</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='personal_information']" position="after">
                    <page string="Documentos" name="documents">
                        <field name="is_readonly_group" invisible="1"/>
                        <field name="document_ids" readonly="is_readonly_group">
                            <list>
                                <field name="name"/>
                                <field name="file"/>
                            </list>
                            <form>
                                <group>
                                    <field name="name"/>
                                    <field name="file"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>

