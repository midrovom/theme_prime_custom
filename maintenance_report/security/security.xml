<record id="group_attachment_hr_readonly_custom" model="res.groups">
    <field name="name">Adjuntos empleados: Solo lectura (Custom)</field>
    <field name="category_id" ref="base.module_category_hidden"/>
</record>

<record id="rule_attachment_hr_readonly_custom" model="ir.rule">
    <field name="name">HR Attachments Readonly Custom</field>
    <field name="model_id" ref="base.model_ir_attachment"/>
    <field name="groups" eval="[(4, ref('maintenance_report.group_attachment_hr_readonly_custom'))]"/>
    <field name="domain_force">[('res_model','=','hr.employee')]</field>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="False"/>
    <field name="perm_create" eval="False"/>
    <field name="perm_unlink" eval="False"/>
</record>
