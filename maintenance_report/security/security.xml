<!-- Grupo de seguridad -->
<record id="group_attachment_view_download" model="res.groups">
    <field name="name">Adjuntos: Usuario</field>
    <field name="category_id" ref="base.module_category_hidden"/>
</record>

<!-- ACL: solo lectura sobre ir.attachment -->
<record id="access_attachment_view_download" model="ir.model.access">
    <field name="name">attachment.view.download</field>
    <field name="model_id" ref="base.model_ir_attachment"/>
    <field name="group_id" ref="module_name.group_attachment_view_download"/>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="False"/>
    <field name="perm_create" eval="False"/>
    <field name="perm_unlink" eval="False"/>
</record>

<!-- Record Rule: restringir acciones a solo lectura -->
<record id="rule_attachment_view_download" model="ir.rule">
    <field name="name">Attachment view/download only</field>
    <field name="model_id" ref="base.model_ir_attachment"/>
    <field name="groups" eval="[(4, ref('module_name.group_attachment_view_download'))]"/>
    <!-- dominio: todos los adjuntos son visibles -->
    <field name="domain_force">[(1,'=',1)]</field>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="False"/>
    <field name="perm_create" eval="False"/>
    <field name="perm_unlink" eval="False"/>
</record>
