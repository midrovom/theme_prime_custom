<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <!-- Grupo personalizado -->
        <record id="group_attachment_hr_readonly_custom" model="res.groups">
            <field name="name">Adjuntos empleados: Solo lectura (Custom)</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <!-- Record Rule: restringe acciones solo en adjuntos ligados a empleados -->
        <record id="rule_attachment_hr_readonly_custom" model="ir.rule">
            <field name="name">HR Attachments Readonly Custom</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="groups" eval="[(4, ref('tu_modulo.group_attachment_hr_readonly_custom'))]"/>
            <!-- dominio: solo adjuntos vinculados al modelo hr.employee -->
            <field name="domain_force">[('res_model','=','hr.employee')]</field>
            <!-- permisos: solo lectura -->
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
