<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Grupo de acceso -->
        <record id="group_attachment_admin" model="res.groups">
            <field name="name">Administrador de Documentos</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>

        <!-- Acceso completo para el grupo Administrador -->
        <record id="access_attachment_admin" model="ir.model.access">
            <field name="name">ir.attachment full access</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="group_id" ref="group_attachment_admin"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Acceso solo lectura para usuarios estándar -->
        <record id="access_attachment_user" model="ir.model.access">
            <field name="name">ir.attachment read only</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

    </data>
</odoo>
