<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_maintenance_report_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.report.wizard.form</field>
        <field name="model">maintenance.report.wizard</field>
        <field name="arch" type="xml">

            <form string="Generar Acta">

                <group>
                    <field name="entregado_por_id" widget="many2one_avatar_employee" domain="[('department_id.responsable_entrega_equipo','=',True)]"/>
                </group>

                <footer>

                    <button name="action_generate_report" type="object" string="Generar PDF" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>

                </footer>

            </form>

        </field>
    </record>

</odoo>