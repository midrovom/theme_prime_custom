<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-inherit="mail.Chatter"
       t-inherit-mode="extension">

        <!-- SEND MESSAGE -->
        <xpath expr="//button[contains(@class,'o-mail-Chatter-sendMessage')]"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

        <!-- LOG NOTE -->
        <xpath expr="//button[contains(@class,'o-mail-Chatter-logNote')]"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

        <!-- ACTIVITIES -->
        <xpath expr="//button[contains(@class,'o-mail-Chatter-activity')]"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

        <!-- FILE UPLOADER TOP -->
        <xpath expr="//FileUploader[1]"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

        <!-- FILE UPLOADER BOTTOM -->
        <xpath expr="//div[contains(@class,'o-mail-AttachmentBox')]//FileUploader"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

        <!-- COMPOSER -->
        <xpath expr="//Composer"
               position="attributes">

            <attribute name="t-if">
                !this.isReadonlyChatter
            </attribute>

        </xpath>

    </t>

</templates>