<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_equipment">
        <t t-call="web.basic_layout">
            <div class="page">
                <h2 style="text-align:center;">ACTA DE ENTREGA DE EQUIPO</h2>
                <t t-foreach="docs" t-as="equipment">
                    <div style="margin-top:20px; border:1px solid #000; padding:15px; border-radius:6px;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td><strong>Nombre del Equipo:</strong></td>
                                <td t-out="equipment.name"/>
                            </tr>
                            <tr>
                                <td><strong>Modelo:</strong></td>
                                <td t-out="equipment.model"/>
                            </tr>
                            <tr>
                                <td><strong>Número de Serie:</strong></td>
                                <td t-out="equipment.serial_no"/>
                            </tr>
                            <tr>
                                <td><strong>Ubicación:</strong></td>
                                <td t-out="equipment.location"/>
                            </tr>
                        </table>

                        <h3 style="margin-top:20px;">Datos del Responsable</h3>
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td><strong>Nombre:</strong></td>
                                <td t-out="equipment.employee_id.name"/>
                            </tr>
                            <tr>
                                <td><strong>Cédula:</strong></td>
                                <td t-out="equipment.employee_id.identification_id"/>
                            </tr>
                            <tr>
                                <td><strong>Departamento:</strong></td>
                                <td t-out="equipment.employee_id.department_id.name"/>
                            </tr>
                        </table>

                        <h3 style="margin-top:20px;">Firmas</h3>
                        <table style="width:100%; border-collapse:collapse; margin-top:10px;">
                            <tr>
                                <td style="width:50%; text-align:center;">
                                    <strong>ENTREGA</strong><br/><br/><br/>
                                    ___________________________<br/>
                                    Nombre:<br/>
                                    Cédula:
                                </td>
                                <td style="width:50%; text-align:center;">
                                    <strong>RECIBE</strong><br/><br/><br/>
                                    ___________________________<br/>
                                    <span t-out="equipment.employee_id.name"/><br/>
                                    <span t-out="equipment.employee_id.identification_id"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>
