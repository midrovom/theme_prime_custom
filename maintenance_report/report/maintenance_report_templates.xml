<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_equipment">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: 'Times New Roman', serif; line-height:1.6; font-size:13px; color:#000;">
                <h2 style="text-align:center; margin-bottom:10px; text-transform:uppercase; letter-spacing:1px; font-weight:bold;">
                    Acta de Entrega de Equipos
                </h2>

                <!-- Fecha y lugar -->
                <p style="margin-top:25px; text-align:justify;">
                    <strong>Guayaquil, <span t-esc="datetime.date.today().strftime('%d/%m/%Y')"/></strong>
                </p>

                <!-- Texto inicial -->
                <p style="margin-top:15px; text-align:justify;">
                    <strong><span t-out="docs[0].partner_id.name"/></strong> en calidad de patrono hace entrega al Señor(a)  
                    <strong><span t-out="docs[0].employee_id.name"/></strong>, con cédula de identidad N° 
                    <strong><span t-out="docs[0].employee_id.identification_id"/></strong> los siguientes equipos: 
                </p>

                <!-- Tabla de equipos -->
                <table style="margin-top:20px; width:100%; border-collapse:collapse; font-size:12px;" border="1">
                    <thead>
                        <tr style="background-color:#f0f0f0; text-align:center;">
                            <th style="padding:5px; font-weight:bold;">Equipo</th>
                            <th style="padding:5px; font-weight:bold;">Modelo</th>
                            <th style="padding:5px; font-weight:bold;">Serie</th>
                            <th style="padding:5px; font-weight:bold;">Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="equipment">
                            <tr>
                                <td style="padding:5px;"><span t-out="equipment.name"/></td>
                                <td style="padding:5px;"><span t-out="equipment.model or ''"/></td>
                                <td style="padding:5px;"><span t-out="equipment.serial_no or ''"/></td>
                                <td style="padding:5px;"><span t-out="equipment.note or ''"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- Compromiso del colaborador -->
                <p style="margin-top:25px; text-align:justify;">
                    El uso inadecuado de los equipos como: robo, caída humedad, perdida; serán motivo de descuento del equipo de mi rol de pago. En 
                    caso de dejar de formar parte de la empresa es de mi conocimiento que debo entregar a mi Supervisor/a el equipo completo, su cargador original.
                </p>

                <!-- Firmas -->
                <div style="margin-top:50px; text-align:center;">
                    <div style="display:inline-block; width:45%; vertical-align:top;">
                        <strong>ENTREGUE CONFORME:</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].entregado_por_id.name"/><br/>
                        C.I. <span t-out="docs[0].entregado_por_id.identification_id"/>
                    </div>

                    <div style="display:inline-block; width:45%; vertical-align:top; margin-left:5%;">
                        <strong>RECIBI CONFORME:</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].employee_id.name"/><br/>
                        <div style="width:100%; text-align:left;">
                            C.I. <span t-out="docs[0].employee_id.identification_id or ''"/>
                        </div>
                    </div>

                    <!-- <div style="display:inline-block; width:45%; vertical-align:top; margin-left:5%;">
                        <strong>RECIBI CONFORME:</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].employee_id.name"/><br/>
                        C.I. <span t-out="docs[0].employee_id.identification_id"/>
                    </div> -->
                </div>

            </div>
        </t>
    </template>
</odoo>
