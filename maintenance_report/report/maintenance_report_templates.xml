<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_equipment">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: 'Times New Roman', serif; line-height:1.6; font-size:13px; color:#000; margin-top:0; padding-top:0;">
                <h2 style="text-align:center; margin-bottom:10px; text-transform:uppercase; letter-spacing:1px; font-weight:bold;">
                    Acta de Entrega de Equipos
                </h2>

                <!-- Fecha y lugar -->
                <p style="margin-top:25px; text-align:justify;">
                    <strong>Guayaquil, <span t-esc="docs[0].create_date.strftime('%d de %B de %Y')"/></strong>
                </p>

                <!-- Texto inicial -->
                <p style="margin-top:15px; text-align:justify;">
                    A través de la presente, yo <strong><span t-out="docs[0].entregado_por_id.name"/></strong>, con C.I. N° 
                    <strong><span t-out="docs[0].entregado_por_id.identification_id"/></strong>, en calidad de representante del 
                    <strong>Departamento de Recursos Humanos</strong> de la empresa ____________________________, procedo a realizar la entrega de los siguientes equipos al/la colaborador(a) 
                    <strong><span t-out="docs[0].employee_id.name"/></strong>, con cédula de identidad N° 
                    <strong><span t-out="docs[0].employee_id.identification_id"/></strong>, quien desempeña el cargo de ____________________________.
                </p>

                <!-- Detalle de equipos -->
                <h3 style="margin-top:20px; text-align:left;">DETALLE DE EQUIPOS ENTREGADOS</h3>
                <div style="margin-top:15px; text-align:left;">
                    <t t-foreach="docs" t-as="equipment">
                        <div style="margin-top:10px; padding:5px; font-size:12px;">
                            <p><strong>Equipo:</strong> <span t-out="equipment.name"/></p>
                            <t t-if="equipment.model">
                                <p><strong>Marca/Modelo:</strong> <span t-out="equipment.model"/></p>
                            </t>
                            <t t-if="equipment.serial_no">
                                <p><strong>Serie:</strong> <span t-out="equipment.serial_no"/></p>
                            </t>
                            <p><strong>Estado:</strong> <span t-out="equipment.note"/></p>
                        </div>
                    </t>
                </div>

                <!-- Compromiso del colaborador -->
                <p style="margin-top:25px; text-align:justify;">
                    El/la colaborador(a) declara haber recibido los equipos en buen estado y se compromete a darles un uso responsable, exclusivamente laboral, 
                    y a devolverlos cuando la empresa lo requiera o al finalizar la relación laboral, salvo el desgaste normal por uso.
                </p>

                <!-- Firmas -->
                <div style="margin-top:50px; text-align:center;">
                    <div style="display:inline-block; width:45%; vertical-align:top;">
                        <strong>ENTREGA (RRHH)</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].entregado_por_id.name"/><br/>
                        C.I. <span t-out="docs[0].entregado_por_id.identification_id"/>
                    </div>

                    <div style="display:inline-block; width:45%; vertical-align:top; margin-left:5%;">
                        <strong>RECIBE (Colaborador)</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].employee_id.name"/><br/>
                        C.I. <span t-out="docs[0].employee_id.identification_id"/>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
