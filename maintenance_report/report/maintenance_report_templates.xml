<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_equipment">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: 'Times New Roman', serif; line-height:1.6; font-size:13px; color:#000; margin-top:0; padding-top:0;">
                <h2 style="text-align:center; margin-bottom:10px; text-transform:uppercase; letter-spacing:1px; font-weight:bold;">
                    Acta de Entrega de Equipo
                </h2>

                <p style="margin-top:25px; text-align:justify;">
                    Por medio de la presente, la empresa certifica la entrega de los equipos de trabajo al colaborador, 
                    necesarios para el adecuado desempeño de sus funciones. El empleado declara haberlos recibido en buen estado 
                    y se compromete a darles un uso responsable y exclusivamente laboral.
                </p>

                <!-- Fecha de entrega -->
                <p style="margin-top:15px; text-align:justify;">
                    Fecha de entrega: <strong><span t-out="docs[0].date"/></strong>
                </p>

                <!-- Equipos -->
                <div style="margin-top:25px; text-align:center;">
                    <t t-foreach="docs" t-as="equipment">
                        <div style="margin-top:15px; padding:5px; text-align:left; font-size:12px; display:inline-block; text-align:left;">
                            <p><strong>Nombre del Equipo:</strong> <span t-out="equipment.name"/></p>
                            <t t-if="equipment.model">
                                <p><strong>Modelo:</strong> <span t-out="equipment.model"/></p>
                            </t>
                            <t t-if="equipment.serial_no">
                                <p><strong>Serie:</strong> <span t-out="equipment.serial_no"/></p>
                            </t>
                            <p><span t-out="equipment.note"/></p>
                        </div>
                    </t>
                </div>

                <!-- Texto mejorado debajo de equipos -->
                <p style="margin-top:25px; text-align:justify;">
                    El colaborador <strong><span t-out="docs[0].employee_id.name"/></strong>, identificado con C.C. 
                    <strong><span t-out="docs[0].employee_id.identification_id"/></strong>, se compromete a mantener los equipos en buenas condiciones, 
                    reportar cualquier novedad y devolverlos cuando la empresa lo requiera o al finalizar la relación laboral, 
                    salvo el desgaste normal por uso.
                </p>

                <div style="margin-top:50px; text-align:center;">
                    <div style="display:inline-block; width:45%; vertical-align:top;">
                        <strong>ENTREGA</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].entregado_por_id.name"/><br/>
                        C.C. <span t-out="docs[0].entregado_por_id.identification_id"/>
                    </div>

                    <div style="display:inline-block; width:45%; vertical-align:top; margin-left:5%;">
                        <strong>RECIBE</strong><br/><br/><br/>
                        ___________________________<br/>
                        <span t-out="docs[0].employee_id.name"/><br/>
                        C.C. <span t-out="docs[0].employee_id.identification_id"/>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
