<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_equipment">
        <t t-call="web.basic_layout">
            <div class="page">
                <h2 style="text-align:center;">ACTA DE ENTREGA DE EQUIPO</h2>
                <p style="margin-top:20px; text-align:justify;">
                    Se deja constancia por parte de la Coordinadora de Recursos Humanos la entrega de los siguientes equipos:
                </p>

                <t t-foreach="docs" t-as="equipment">
                    <div style="margin-top:15px; text-align:center; padding:10px;">
                        <p><strong>Nombre del Equipo:</strong> <span t-out="equipment.name"/></p>
                        <p><strong>Modelo:</strong> <span t-out="equipment.model"/></p>
                        <p><strong>Número de Serie:</strong> <span t-out="equipment.serial_no"/></p>
                        <p><strong>Ubicación:</strong> <span t-out="equipment.location"/></p>
                    </div>
                </t>

                <p style="margin-top:20px; text-align:justify;">
                    Al trabajador <strong><span t-out="docs[0].employee_id.name"/></strong>, identificado con C.C. 
                    <strong><span t-out="docs[0].employee_id.identification_id"/></strong>, se le entrega el equipo en buen estado físico y de funcionamiento. 
                    El trabajador se compromete a mantenerlo en estas condiciones y a darle el uso adecuado.
                </p>

                <div style="margin-top:30px; text-align:center;">
                    <p><strong>ENTREGA</strong></p>
                    <p>___________________________</p>
                    <p><span t-out="docs[0].entregado_por_id.name"/></p>
                    <p><span t-out="docs[0].entregado_por_id.identification_id"/></p>
                </div>

                <div style="margin-top:50px; text-align:center;">
                    <p><strong>RECIBE</strong></p>
                    <p>___________________________</p>
                    <p><span t-out="docs[0].employee_id.name"/></p>
                    <p><span t-out="docs[0].employee_id.identification_id"/></p>
                </div>
            </div>
        </t>
    </template>
</odoo>
