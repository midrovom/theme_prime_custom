<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="maintenance_equipment_report" model="ir.actions.report">
        <field name="name">Acta Entrega</field>
        <field name="model">maintenance.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">maintenance_report.report_equipment</field>
        <field name="report_file">maintenance_report.report_equipment</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <record id="maintenance_equipment_return_report" model="ir.actions.report">
        <field name="name">Acta Devolucion</field>
        <field name="model">maintenance.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">maintenance_report.report_equipment_return</field>
        <field name="report_file">maintenance_report.report_equipment_return</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- ACCION WIZARD ENTREGA -->

    <record id="action_open_delivery_wizard" model="ir.actions.server">
        <field name="name">Generar Acta de Entrega</field>
        <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_type">action</field>

        <field name="state">code</field>

        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'maintenance.report.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'default_equipment_ids': [(6, 0, records.ids)],
        'default_report_type': 'delivery',
    }
}
        </field>
    </record>

    <!-- ACCION WIZARD DEVOLUCION -->

    <record id="action_open_return_wizard" model="ir.actions.server">
        <field name="name">Generar Acta de Devolución</field>
        <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="binding_type">action</field>

        <field name="state">code</field>

        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'maintenance.report.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'default_equipment_ids': [(6, 0, records.ids)],
        'default_report_type': 'return',
    }
}
        </field>
    </record>

</odoo>