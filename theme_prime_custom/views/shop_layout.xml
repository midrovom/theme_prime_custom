<odoo>

    <data>
    
        <record id="view_filter_price_inherit" model="ir.ui.view">
            <field name="name">theme_prime.filter.price.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="theme_prime.view_filter_attributes"/>
            <field name="arch" type="xml">
                <xpath expr="//form[@class='js_attributes']//span[normalize-space(text())='Price']" position="replace">
                    <span>Precio</span>
                </xpath>
            </field>
        </record>

    </data>
    
</odoo>
