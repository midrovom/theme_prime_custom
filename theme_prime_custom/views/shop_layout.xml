<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="component_account_info_inherit" inherit_id="theme_prime.component_account_info" name="Component Account Info Inherit">
    
    <xpath expr="//small//t[normalize-space(text())='Account']" position="replace">
      <t>Cuenta</t>
    </xpath>
    <xpath expr="//small[normalize-space(text())='Wishlist']" position="replace">
      <small class="d-inline-block">Lista de deseos</small>
    </xpath>
    <xpath expr="//small[normalize-space(text())='My Cart']" position="replace">
      <small class="d-inline-block">Mi Carrito</small>
    </xpath>
    <xpath expr="//small[normalize-space(text())='Search']" position="replace">
      <small class="d-inline-block">Buscar</small>
    </xpath>

  </template>

  <template id="shop_layout_filters_inherit" inherit_id="theme_prime.shop_layout_filters" name="Theme Prime: Shop Layout Filters Inherit">

    <xpath expr="//form[@class='js_attributes']//span[normalize-space(text())='Price']" position="replace">
      <span>Precio</span>
    </xpath>

  </template>
  
  <template id="cart_sidebar_inherit" inherit_id="theme_prime.cart_sidebar" name="Theme Prime: Cart Sidebar Inherit">

    <xpath expr="//h5[normalize-space(text())='Your Cart']/text()" position="replace">
      Tu Carrito
    </xpath>

    <xpath expr="//a[normalize-space(text())='(Clear Cart)']/text()" position="replace">
      (Vaciar Carrito)
    </xpath>

    <xpath expr="//button[contains(@class,'btn-close')]" position="attributes">
      <attribute name="title">Cerrar</attribute>
      <attribute name="aria-label">Cerrar</attribute>
    </xpath>

    <xpath expr="//h6[normalize-space(text())='Subtotal']/text()" position="replace">
      Subtotal
    </xpath>

    <xpath expr="//h6[normalize-space(text())='Taxes']/text()" position="replace">
      Impuestos
    </xpath>

    <xpath expr="//a[normalize-space(text())='Apply promo code']/text()" position="replace">
      Aplicar código promocional
    </xpath>

    <xpath expr="//div[contains(text(),'You are eligible for')]/text()" position="replace">
      ¡Eres elegible para envío gratis!
    </xpath>

    <xpath expr="//div[contains(text(),'away from')]/text()" position="replace">
      Te faltan
    </xpath>

    <xpath expr="//span[contains(@class,'tp-total-cart-items')]/text()" position="replace">
      artículos
    </xpath>

    <xpath expr="//small[normalize-space(text())='Proceed']/text()" position="replace">
      Continuar
    </xpath>

    <xpath expr="//h5[normalize-space(text())='Your cart is empty!']/text()" position="replace">
      ¡Tu carrito está vacío!
    </xpath>

    <xpath expr="//a[normalize-space(text())='Shop Now']/text()" position="replace">
      Comprar ahora
    </xpath>

  </template>

</odoo>




