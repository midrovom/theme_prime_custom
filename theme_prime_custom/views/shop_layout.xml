<odoo>
  <template id="component_account_info_inherit" inherit_id="theme_prime.component_account_info" name="Component Account Info Inherit">
    
    <xpath expr="//small//t[normalize-space(text())='Account']" position="replace">
      <t>Cuenta</t>
    </xpath>
    <xpath expr="//small[normalize-space(text())='Wishlist']" position="replace">
      <small class="d-inline-block">Lista de deseos</small>
    </xpath>
    <xpath expr="//small[normalize-space(text())='My Cart']" position="replace">
      <small class="d-inline-block">Mi Carrito</small>
    </xpath>
    <xpath expr="//small[normalize-space(text())='Search']" position="replace">
      <small class="d-inline-block">Buscar</small>
    </xpath>

  </template>

  <template id="shop_layout_filters_inherit" inherit_id="theme_prime.shop_layout_filters" name="Theme Prime: Shop Layout Filters Inherit">

    <xpath expr="//form[@class='js_attributes']//span[normalize-space(text())='Price']" position="replace">
      <span>Precio</span>
    </xpath>

  </template>
  
