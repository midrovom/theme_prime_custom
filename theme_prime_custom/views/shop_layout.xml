        <record id="component_account_info_inherit" model="ir.ui.view">
            <field name="name">component.account.info.inherit</field>
            <field name="model">website</field>
            <field name="inherit_id" ref="theme_prime.component_account_info"/>
            <field name="arch" type="xml">

                <xpath expr="//small[normalize-space(text())='Login']" position="replace">
                    <small class="d-inline-block">Iniciar Sesión</small>
                </xpath>

                <xpath expr="//small[normalize-space(text())='Account']" position="replace">
                    <small class="d-inline-block">Cuenta</small>
                </xpath>

                <xpath expr="//small[normalize-space(text())='Wishlist']" position="replace">
                    <small class="d-inline-block">Lista de deseos</small>
                </xpath>

                <xpath expr="//small[normalize-space(text())='My Cart']" position="replace">
                    <small class="d-inline-block">Mi Carrito</small>
                </xpath>

                <xpath expr="//small[normalize-space(text())='Search']" position="replace">
                    <small class="d-inline-block">Buscar</small>
                </xpath>
            </field>
        </record>

    </data>
    
