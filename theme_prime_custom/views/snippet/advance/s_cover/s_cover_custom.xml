<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_cover_3_carousel" name="Cover con Carousel">
        <section class="s_cover_3 o_colored_level pt32 pb32" data-snippet="s_carousel" data-name="Carousel">
            <div id="myCarouselTest" class="carousel slide s_carousel tp-custom-carousel" data-bs-ride="carousel"
                 data-bs-interval="8000" so_content_addition_selector=".carousel-inner">
                <div class="carousel-inner">
                    <div class="carousel-item active p-0" data-name="Slide">
                        <div class="container-fluid px-0">
                            <div class="row g-0 align-items-center" style="min-height:300px;">
                                <div class="col-12 col-lg-6 p-4 o_editable">
                                    <div class="jumbotron rounded o_cc o_cc1 border p-4 oe_structure">

                                        <h3 class="o_default_snippet_text">
                                            New Arrivals
                                        </h3>

                                        <h2 class="display-4 fw-bold o_default_snippet_text">
                                            Fresh Collection By Prime
                                        </h2>

                                        <p class="lead o_default_snippet_text">
                                            In hac habitasse platea dictumst.
                                            Praesent cursus congue felis.
                                        </p>

                                        <a href="/shop"
                                           class="btn btn-primary rounded-pill mt-2">
                                            Discover More
                                        </a>

                                    </div>

                                </div>

                                <div class="col-12 col-lg-6 text-center o_editable">
                                    <img class="img-fluid oe_img" style="max-height:300px; object-fit:contain;" src="/web/image/theme_prime.s_cover_3_1" alt="Cover Image 01"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Slide #02 -->
                    <div class="carousel-item p-0" data-name="Slide">
                        <div class="container-fluid px-0">
                            <div class="row g-0 align-items-center" style="min-height:300px;">
                                <div class="col-12 col-lg-6 p-4 o_editable">
                                    <div class="jumbotron rounded o_cc o_cc1 border p-4 oe_structure">
                                        <h3 class="o_default_snippet_text">
                                            Special Offer
                                        </h3>

                                        <h2 class="display-4 fw-bold o_default_snippet_text">
                                            Exclusive Deals
                                        </h2>

                                        <p class="lead o_default_snippet_text">
                                            Get the best discounts on our premium products.
                                        </p>

                                        <a href="/shop"
                                           class="btn btn-primary rounded-pill mt-2">
                                            Shop Now
                                        </a>

                                    </div>
                                </div>

                                <div class="col-12 col-lg-6 text-center o_editable">
                                    <img class="img-fluid oe_img" style="max-height:300px; object-fit:contain;" src="/web/image/theme_prime.s_cover_3_2" alt="Cover Image 02"/>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button class="carousel-control-prev o_not_editable" type="button" data-bs-target="#myCarouselTest" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next o_not_editable" type="button" data-bs-target="#myCarouselTest" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

                <div class="carousel-indicators o_not_editable">
                    <button type="button" data-bs-target="#myCarouselTest" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#myCarouselTest" data-bs-slide-to="1"></button>
                </div>
            </div>
        </section>

    </template>

</odoo>