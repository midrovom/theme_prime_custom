<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="s_cover_3_carousel" name="Cover con Carousel">
    <section class="s_cover_3">
        
        <div id="myCarouselTest"
             class="tp-custom-carousel s_carousel s_carousel_rounded carousel slide"
             data-bs-ride="carousel"
             data-bs-interval="8000">
            
            <!-- Slides -->
            <div class="carousel-inner">
                
                <!-- Slide #01 -->
                <div class="carousel-item p-0 active" data-name="Slide">
                    
                    <div class="d-flex align-items-center justify-content-between"
                         style="min-height:300px;">

                        <!-- TEXTO -->
                        <div style="flex:1; padding:40px;">
                            <h3>New Arrivals</h3>
                            <h2 class="display-4 fw-bold">Fresh Collection By Prime</h2>
                            <p class="lead">
                                In hac habitasse platea dictumst. Praesent cursus congue felis, nec pellentesque nulla ornare sed.
                            </p>
                            <a href="/shop" class="btn btn-primary mt-2 rounded-pill">
                                Discover More
                            </a>
                        </div>

                        <!-- IMAGEN -->
                        <div style="
                            flex:1;
                            height:300px;
                            background-image:url('/web/image/theme_prime.s_cover_3_1');
                            background-repeat:no-repeat;
                            background-position:center;
                            background-size:contain;">
                        </div>

                    </div>

                </div>

                <!-- Slide #02 -->
                <div class="carousel-item p-0" data-name="Slide">
                    
                    <div class="d-flex align-items-center justify-content-between"
                         style="min-height:300px;">

                        <!-- TEXTO -->
                        <div style="flex:1; padding:40px;">
                            <h3>Special Offer</h3>
                            <h2 class="display-4 fw-bold">Exclusive Deals</h2>
                            <p class="lead">
                                Get the best discounts on our premium products. Limited time only!
                            </p>
                            <a href="/shop" class="btn btn-primary mt-2 rounded-pill">
                                Shop Now
                            </a>
                        </div>

                        <!-- IMAGEN -->
                        <div style="
                            flex:1;
                            height:300px;
                            background-image:url('/web/image/theme_prime.s_cover_3_2');
                            background-repeat:no-repeat;
                            background-position:center;
                            background-size:contain;">
                        </div>

                    </div>

                </div>

            </div>

            <!-- Controls -->
            <button class="carousel-control-prev o_not_editable"
                    data-bs-target="#myCarouselTest"
                    data-bs-slide="prev">
                <span class="carousel-control-prev-icon"/>
            </button>

            <button class="carousel-control-next o_not_editable"
                    data-bs-target="#myCarouselTest"
                    data-bs-slide="next">
                <span class="carousel-control-next-icon"/>
            </button>

            <!-- Indicators -->
            <div class="carousel-indicators o_not_editable">
                <button type="button" data-bs-target="#myCarouselTest" data-bs-slide-to="0" class="active"/>
                <button type="button" data-bs-target="#myCarouselTest" data-bs-slide-to="1"/>
            </div>

        </div>
    </section>
</template>
</odoo>