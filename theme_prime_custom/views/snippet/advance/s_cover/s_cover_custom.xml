<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="s_cover_3_carousel" name="Cover con Carousel">
    <section class="s_cover_3">
        <!-- Generar ID único -->
        <t t-set="uniq" t-value="datetime.datetime.now().microsecond"/>
        <div t-attf-id="myCarousel{{uniq}}" class="tp-custom-carousel s_carousel s_carousel_rounded carousel slide" data-bs-interval="8000">
            
            <!-- Slides -->
            <div class="carousel-inner">
                <!-- Slide #01 -->
                <div class="carousel-item p-0 active" data-name="Slide">
                    <div class="container-fluid px-0">
                        <div class="row content g-0 align-items-center s_col_no_bgcolor s_nb_column_fixed">
                            <div class="jumbotron rounded px-4 offset-lg-1 col-lg-5 pt32 pb32 o_cc o_cc1 border" data-name="Box">
                                <h3>New Arrivals</h3>
                                <h2 class="display-4 fw-bold">Fresh Collection By Prime</h2>
                                <p class="lead">In hac habitasse platea dictumst. Praesent cursus congue felis, nec pellentesque nulla ornare sed.</p>
                                <a href="/shop" class="btn btn-primary mt-2 rounded-circle">Discover More</a>
                            </div>
                            <div class="order-1 order-lg-2 offset-lg-1 col-lg-6">
                                <img class="img img-fluid" src="/web/image/theme_prime.s_cover_3_1" alt="Cover Image 01"/>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Slide #02 -->
                <div class="carousel-item p-0" data-name="Slide">
                    <div class="container-fluid px-0">
                        <div class="row content g-0 align-items-center s_col_no_bgcolor s_nb_column_fixed">
                            <div class="jumbotron rounded px-4 offset-lg-1 col-lg-5 pt32 pb32 o_cc o_cc1 border" data-name="Box">
                                <h3>Special Offer</h3>
                                <h2 class="display-4 fw-bold">Exclusive Deals</h2>
                                <p class="lead">Get the best discounts on our premium products. Limited time only!</p>
                                <a href="/shop" class="btn btn-primary mt-2 rounded-circle">Shop Now</a>
                            </div>
                            <div class="order-1 order-lg-2 offset-lg-1 col-lg-6">
                                <img class="img img-fluid" src="/web/image/theme_prime.s_cover_3_2" alt="Cover Image 02"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Controls -->
            <button class="carousel-control-prev o_not_editable" contenteditable="false" t-attf-data-bs-target="#myCarousel{{uniq}}" data-bs-slide="prev" aria-label="Previous" title="Previous">
                <span class="carousel-control-prev-icon" aria-hidden="true"/>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next o_not_editable" contenteditable="false" t-attf-data-bs-target="#myCarousel{{uniq}}" data-bs-slide="next" aria-label="Next" title="Next">
                <span class="carousel-control-next-icon" aria-hidden="true"/>
                <span class="visually-hidden">Next</span>
            </button>

            <!-- Indicators -->
            <div class="carousel-indicators o_not_editable">
                <button type="button" t-attf-data-bs-target="#myCarousel{{uniq}}" data-bs-slide-to="0" class="active"/>
                <button type="button" t-attf-data-bs-target="#myCarousel{{uniq}}" data-bs-slide-to="1"/>
            </div>
        </div>
    </section>
</template>

    

</odoo>
