<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="ChatToCompany_1" name="Chat With Company" inherit_id="theme_prime.template_footer_style_1">
        <xpath expr="//div[@id='footer']" position="inside">
            <a t-attf-href="https://api.whatsapp.com/send?phone=#{website.mobile_number}&amp;text="
               class="cy_whatsapp_web" target="_blank">
                <i class="fa fa-whatsapp cy-icon"/>
            </a>
        </xpath>
    </template>

