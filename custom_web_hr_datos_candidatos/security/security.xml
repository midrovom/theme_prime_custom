<odoo>
    <!-- Grupo de seguridad -->
    <record id="group_hr_recruitment_readonly" model="res.groups">
        <field name="name">Reclutamiento - Solo Lectura</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <!-- Regla de acceso: solo lectura sobre hr.applicant -->
    <record id="rule_hr_applicant_readonly" model="ir.rule">
        <field name="name">Solo Lectura Postulantes</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('group_hr_recruitment_readonly'))]"/>
        <!-- Dominio: todos los registros -->
        <field name="domain_force">[(1,'=',1)]</field>
        <!-- Permisos: solo lectura -->
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
