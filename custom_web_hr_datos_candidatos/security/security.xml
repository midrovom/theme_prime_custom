<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reglas de solo lectura para todos los modelos del postulante -->
    <record id="rule_applicant_readonly" model="ir.rule">
        <field name="name">Hr Applicant Readonly</field>
        <field name="model_id" ref="hr.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

