<odoo>
    <!-- Grupo de seguridad -->
    <record id="group_hr_recruitment_readonly" model="res.groups">
        <field name="name">Reclutamiento - Solo Lectura</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <!-- Regla de acceso: solo lectura sobre hr.applicant -->
    <record id="rule_hr_applicant_readonly" model="ir.rule">
        <field name="name">Postulantes solo lectura</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(4, ref('group_hr_recruitment_readonly'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Vista heredada: todos los campos readonly -->
    <record id="view_applicant_form_readonly" model="ir.ui.view">
        <field name="name">hr.applicant.form.readonly</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
