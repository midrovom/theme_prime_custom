<odoo>
    <data>

        <record id="view_hr_reglamento_form" model="ir.ui.view">
            <field name="name">hr.reglamento.form</field>
            <field name="model">hr.reglamento</field>
            <field name="arch" type="xml">
                <form string="Reglamento">
                    <sheet>
                        <group>
                            <field name="reglamento"/>
                            <field name="footer_reglamento"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_hr_reglamento_list" model="ir.ui.view">
            <field name="name">hr.reglamento.list</field>
            <field name="model">hr.reglamento</field>
            <field name="arch" type="xml">
                <list string="Reglamento">
                    <field name="reglamento"/>
                    <field name="footer_reglamento"/>
                </list>
            </field>
        </record>

        <record id="action_hr_reglamento" model="ir.actions.act_window">
            <field name="name">Reglamento</field>
            <field name="res_model">hr.reglamento</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_applicant_reglamento"
            name="Reglamento"
            parent="menu_hr_recruitment_footer"
            action="action_hr_reglamento"
            sequence="2"
            groups="hr.group_hr_user"/>

    </data>
</odoo>
