<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista formulario -->
        <record id="view_hr_reglamento_form" model="ir.ui.view">
            <field name="name">hr.reglamento.form</field>
            <field name="model">hr.reglamento</field>
            <field name="arch" type="xml">
                <form string="reglamento">
                    <sheet>
                        <group>
                            <field name="reglamento"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista lista -->
        <record id="view_hr_reglamento_list" model="ir.ui.view">
            <field name="name">hr.reglamento.list</field>
            <field name="model">hr.reglamento</field>
            <field name="arch" type="xml">
                <list string="Footer">
                    <field name="reglamento"/>
                </list>
            </field>
        </record>

        <!-- Menús -->
        <menuitem
            id="menu_hr_recruitment_reglamento"
            name="Footer"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="5"/>

        <menuitem
            id="menu_applicant_footer"
            name="Ley de Protección de Datos"
            parent="menu_hr_recruitment_reglamento"
            action="action_hr_footer"
            sequence="1"
            groups="hr.group_hr_user"/>

    </data>
</odoo>
