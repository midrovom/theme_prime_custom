<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista formulario -->
        <record id="view_hr_footer_form" model="ir.ui.view">
            <field name="name">hr.footer.form</field>
            <field name="model">hr.footer</field>
            <field name="arch" type="xml">
                <form string="Footer">
                    <sheet>
                        <group>
                            <field name="descripcion"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista lista -->
        <record id="view_hr_footer_list" model="ir.ui.view">
            <field name="name">hr.footer.list</field>
            <field name="model">hr.footer</field>
            <field name="arch" type="xml">
                <list string="Footer">
                    <field name="descripcion"/>
                </list>
            </field>
        </record>

        <!-- Acción de ventana -->
        <record id="action_hr_footer" model="ir.actions.act_window">
            <field name="name">Footer</field>
            <field name="res_model">hr.footer</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menús -->
        <menuitem
            id="menu_hr_recruitment_footer"
            name="Footer"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="4"/>

        <menuitem
            id="menu_applicant_footer"
            name="Ley de Protección de Datos"
            parent="menu_hr_recruitment_footer"
            action="action_hr_footer"
            sequence="1"
            groups="hr.group_hr_user"/>

    </data>
</odoo>
