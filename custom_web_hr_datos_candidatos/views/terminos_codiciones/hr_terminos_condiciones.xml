<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_inherit_terms" model="ir.ui.view">
        <field name="name">res.users.form.inherit.terms</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <field name="accept_terms"/>
            </xpath>
        </field>
    </record>

    <template id="signup_inherit_terms" inherit_id="auth_signup.signup">
        <xpath expr="//div[@class='text-center oe_login_buttons d-grid pt-3']/a[@role='button']" position="after">
            <div class="form-check mt-2">
                <input type="checkbox" class="form-check-input" id="accept_terms" name="accept_terms"/>
                <label class="form-check-label" for="accept_terms">
                    <a href="/terminos-y-condiciones" target="_blank">Acepto términos y condiciones</a>
                </label>
            </div>
        </xpath>
    </template>

</odoo>

