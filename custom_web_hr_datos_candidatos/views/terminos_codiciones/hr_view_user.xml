<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_accept_terms" model="ir.ui.view">
        <field name="name">res.users.form.inherit.accept.terms</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Insertar después del campo groups_id (Tipo de usuario) -->
            <xpath expr="//field[@name='groups_id']" position="after">
                <field name="accept_terms"/>
            </xpath>
        </field>
    </record>
</odoo>
