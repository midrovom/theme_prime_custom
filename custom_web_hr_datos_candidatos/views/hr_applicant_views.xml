<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hr_applicant_view_form_inherit" model="ir.ui.view">
            <field name="name">hr.applicant.view.form.inherit</field>
            <field name="model">hr.applicant</field>
            <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
            <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_phone']" position="attributes">
                <attribute name="groups">custom_web_hr_datos_candidatos.group_applicant_readonly</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='email_from']" position="attributes">
                <attribute name="groups">custom_web_hr_datos_candidatos.group_applicant_readonly</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='candidate_id']" position="attributes">
                <attribute name="groups">custom_web_hr_datos_candidatos.group_applicant_readonly</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>

                <xpath expr="//field[@name='partner_phone']" position="after">
                    <!-- Datos personales -->
                    <field name="image_1920" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="partner_mobile" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="document_type" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="cedula" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="address" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="parish" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="birthdate" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="age" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="birth_country_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="provincia_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="nacionality" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="vive_con" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="tipo_vivienda" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="num_hijos" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="dependientes" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                    <field name="estado_civil" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>

                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Documentos" name="Documentos Adjuntos">
                        <field name="document_ids">
                            <list>
                                <field name="filename"/>
                                <field name="file" filename="filename"/>
                            </list>
                        </field>
                    </page>
                </xpath>

                <!-- campos ocultos -->
                <xpath expr="//field[@name='linkedin_profile']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='type_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Información Médica" name="page_medical">
                        <field name="medical_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="enfermedad_persistente" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="detalle_enfermedad_persistente" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="medicacion_continua" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="detalle_medicacion_continua" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="enfermedad_laboral" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="detalle_enfermedad_laboral" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="cirugia_realizada" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="detalle_cirugia_realizada" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="discapacidad" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="tipo_discapacidad" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="porcentaje_discapacidad" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="tipo_sangre" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                            </list>
                        </field>
                    </page>

                    <page string="Datos Familiares" name="page_family">
                        <field name="family_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="name" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="cedula" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="birthdate" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="phone" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="occupation" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="economically_dependent" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="disability" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="disability_type" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                            </list>
                        </field>
                    </page>

                    <page string="Formación Académica" name="page_education">
                        <field name="education_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="level_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="institucion" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="fecha_inicio" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="year_fin" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="country_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="state_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="titulo" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="study_current" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>         
                                <field name="titulo_por_obtener" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>  
                                <field name="institucion_2" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/> 
                                <field name="horario" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>              
                                <field name="carrera" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>  
                                <field name="estado" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>             
                            </list>
                        </field>
                    </page>

                    <page string="Experiencia Laboral" name="page_experience">
                        <field name="experience_job_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="tiempo_servicio" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="empresa" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="country_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="state_id" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="telefonos" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="name" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="ingreso_mensual" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="motivo_separacion" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="jefe_directo" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="cargo_jefe_directo" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="fecha_inicio" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="year_fin" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                            </list>
                        </field>
                    </page>


                    <page string="Familiares o Conocidos del Grupo Empresarial" name="page_known">
                        <field name="known_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="posee_familiares" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="nombre_completo" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="relacion" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="parentesco" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                            </list>
                        </field>
                    </page>

                    <page string="Referencias Personales" name="page_reference">
                        <field name="reference_ids" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1">
                            <list>
                                <field name="nombre" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="domicilio" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="telefono" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="ocupacion" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                                <field name="tiempo_conocerlo" groups="custom_web_hr_datos_candidatos.group_applicant_readonly" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>

        <!-- Formación Académica -->
        <menuitem
            id="menu_hr_recruitment_academic_training"
            name="Formación Académica"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="1"/>

        <menuitem
            id="hr_recruitment.menu_hr_recruitment_degree"
            parent="menu_hr_recruitment_academic_training"
            action="hr_recruitment.hr_recruitment_degree_action"
            sequence="1"/>

        <!-- Datos Personales -->
        <!-- <menuitem
            id="menu_hr_recruitment_Datos_Personales"
            name="Datos Personales"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="2"/>

        <menuitem
            id="menu_applicant_family"
            name="Datos Familiares"
            parent="menu_hr_recruitment_Datos_Personales"
            action="applicant_family_action"
            sequence="1"
            groups="base.group_no_one"/>

        <menuitem
            id="menu_applicant_medical"
            name="Información Médica"
            parent="menu_hr_recruitment_Datos_Personales"
            action="hr_applicant_medical_action"
            sequence="2"
            groups="hr.group_hr_user"/> -->

        <!-- Experiencia Laboral -->

        <menuitem
            id="menu_hr_recruitment_job_experience"
            name="Experiencia Laboral"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="3"/>

    </data>


</odoo>
