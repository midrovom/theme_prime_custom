<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hr_applicant_view_form_inherit" model="ir.ui.view">
            <field name="name">hr.applicant.view.form.inherit</field>
            <field name="model">hr.applicant</field>
            <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_phone']" position="attributes">
                    <attribute name="readonly">is_readonly_group</attribute>
                </xpath>

                <xpath expr="//field[@name='email_from']" position="attributes">
                    <attribute name="readonly">is_readonly_group</attribute>
                </xpath>

                <xpath expr="//field[@name='candidate_id']" position="attributes">
                    <attribute name="readonly">is_readonly_group</attribute>
                </xpath>

                <xpath expr="//field[@name='partner_phone']" position="after">

                    <field name="is_readonly_group" invisible="1"/>
                    <!-- Datos personales -->
                    <field name="image_1920" readonly="is_readonly_group"/>
                    <field name="partner_mobile" readonly="is_readonly_group"/>
                    <field name="document_type" readonly="is_readonly_group"/>
                    <field name="cedula" readonly="is_readonly_group"/>
                    <field name="address" readonly="is_readonly_group"/>
                    <field name="parish" readonly="is_readonly_group"/>
                    <field name="birthdate" readonly="is_readonly_group"/>
                    <field name="age" readonly="is_readonly_group"/>
                    <field name="birth_country_id" readonly="is_readonly_group"/>
                    <field name="provincia_id" readonly="is_readonly_group"/>
                    <field name="nacionality" readonly="is_readonly_group"/>
                    <field name="vive_con" readonly="is_readonly_group"/>
                    <field name="tipo_vivienda" readonly="is_readonly_group"/>
                    <field name="num_hijos" readonly="is_readonly_group"/>
                    <field name="dependientes" readonly="is_readonly_group"/>
                    <field name="estado_civil" readonly="is_readonly_group"/>

                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Documentos" name="Documentos Adjuntos">
                        <field name="is_readonly_group" invisible="1"/>
                        <field name="document_ids" readonly="is_readonly_group">
                            <list>
                                <field name="filename"/>
                                <field name="file" filename="filename"/>
                            </list>
                        </field>
                    </page>
                </xpath>

                <!-- campos ocultos -->
                <xpath expr="//field[@name='linkedin_profile']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='type_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//notebook" position="inside">

                 <field name="is_readonly_group" invisible="1"/>

                    <page string="Información Médica" name="page_medical">
                        <field name="medical_ids" readonly="is_readonly_group">
                            <list>
                                <field name="enfermedad_persistente"/>
                                <field name="detalle_enfermedad_persistente"/>
                                <field name="medicacion_continua"/>
                                <field name="detalle_medicacion_continua"/>
                                <field name="enfermedad_laboral"/>
                                <field name="detalle_enfermedad_laboral"/>
                                <field name="cirugia_realizada"/>
                                <field name="detalle_cirugia_realizada"/>
                                <field name="discapacidad"/>
                                <field name="tipo_discapacidad"/>
                                <field name="porcentaje_discapacidad"/>
                                <field name="tipo_sangre"/>
                            </list>
                        </field>
                    </page>

                    <page string="Datos Familiares" name="page_family">
                        <field name="family_ids" readonly="is_readonly_group">
                            <list>
                                <field name="name"/>
                                <field name="cedula"/>
                                <field name="birthdate"/>
                                <field name="phone"/>
                                <field name="occupation"/>
                                <field name="economically_dependent"/>
                                <field name="disability"/>
                                <field name="disability_type"/>
                            </list>
                        </field>
                    </page>

                    <page string="Formación Académica" name="page_education">
                        <field name="education_ids" readonly="is_readonly_group">
                            <list>
                                <field name="level_id"/>
                                <field name="institucion"/>
                                <field name="fecha_inicio"/>
                                <field name="year_fin"/>
                                <field name="country_id"/>
                                <field name="state_id"/>
                                <field name="titulo"/>
                                <field name="study_current"/>         
                                <field name="titulo_por_obtener"/>  
                                <field name="institucion_2"/> 
                                <field name="horario"/>              
                                <field name="carrera"/>  
                                <field name="estado"/>             
                            </list>
                        </field>
                    </page>

                    <page string="Experiencia Laboral" name="page_experience">
                        <field name="experience_job_ids" readonly="is_readonly_group">
                            <list>
                                <field name="tiempo_servicio"/>
                                <field name="empresa"/>
                                <field name="country_id"/>
                                <field name="state_id"/>
                                <field name="telefonos"/>
                                <field name="name"/>
                                <field name="ingreso_mensual"/>
                                <field name="motivo_separacion"/>
                                <field name="jefe_directo"/>
                                <field name="cargo_jefe_directo"/>
                                <field name="fecha_inicio"/>
                                <field name="year_fin"/>
                            </list>
                        </field>
                    </page>


                    <page string="Familiares o Conocidos del Grupo Empresarial" name="page_known">
                        <field name="known_ids" readonly="is_readonly_group">
                            <list>
                                <field name="posee_familiares"/>
                                <field name="nombre_completo"/>
                                <field name="relacion"/>
                                <field name="parentesco"/>
                            </list>
                        </field>
                    </page>

                    <page string="Referencias Personales" name="page_reference">
                        <field name="reference_ids" readonly="is_readonly_group">
                            <list>
                                <field name="nombre"/>
                                <field name="domicilio"/>
                                <field name="telefono"/>
                                <field name="ocupacion"/>
                                <field name="tiempo_conocerlo"/>
                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>

        <!-- Formación Académica -->
        <menuitem
            id="menu_hr_recruitment_academic_training"
            name="Formación Académica"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="1"/>

        <menuitem
            id="hr_recruitment.menu_hr_recruitment_degree"
            parent="menu_hr_recruitment_academic_training"
            action="hr_recruitment.hr_recruitment_degree_action"
            sequence="1"/>

        <!-- Datos Personales -->
        <!-- <menuitem
            id="menu_hr_recruitment_Datos_Personales"
            name="Datos Personales"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="2"/>

        <menuitem
            id="menu_applicant_family"
            name="Datos Familiares"
            parent="menu_hr_recruitment_Datos_Personales"
            action="applicant_family_action"
            sequence="1"
            groups="base.group_no_one"/>

        <menuitem
            id="menu_applicant_medical"
            name="Información Médica"
            parent="menu_hr_recruitment_Datos_Personales"
            action="hr_applicant_medical_action"
            sequence="2"
            groups="hr.group_hr_user"/> -->

        <!-- Experiencia Laboral -->

        <menuitem
            id="menu_hr_recruitment_job_experience"
            name="Experiencia Laboral"
            parent="hr_recruitment.menu_hr_recruitment_config_applications"
            sequence="3"/>

    </data>


</odoo>
