<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mail_server_form_inherit_recruitment" model="ir.ui.view">
        <field name="name">ir.mail_server.form.inherit.recruitment</field>
        <field name="model">ir.mail_server</field>
        <field name="inherit_id" ref="base.view_mail_server_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='smtp_user']" position="after">
                <field name="is_recruitment_server"/>
            </xpath>
        </field>
    </record>
    
</odoo>
