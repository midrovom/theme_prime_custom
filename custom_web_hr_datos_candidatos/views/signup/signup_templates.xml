<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="signup_with_code" inherit_id="auth_signup.signup">
        <xpath expr="//form" position="inside">
            <div class="form-group mt-3">
                <label for="verification_code">Código de verificación</label>
                <input type="text" name="verification_code" class="form-control" required="required"/>
            </div>
        </xpath>
    </template>
</odoo>
