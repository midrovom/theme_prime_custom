<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_applicant_test">
        <t t-call="web.basic_layout">

            <t t-foreach="docs" t-as="applicant">

                <div class="page" style="font-size:12px; font-family:'Times New Roman', Times, serif;">

                    <table style="width:100%; border-collapse:collapse; table-layout:fixed; font-size:12px;">
                        <tr>
                            <th colspan="4" style="border:1px solid #000; background:#e6e6e6;">
                                ACTUALIZACIÓN DE DATOS PARA CANDIDATOS
                            </th>
                        </tr>

                        <tr>
                            <td colspan="" style="border:1px solid #000; vertical-align:top; word-break:break-word; line-height:1.3; padding:10px;">
                                <t t-raw="applicant.reglamento_id.reglamento"/>
                            </td>

                            <!-- <td colspan="2" style="border:1px solid #000; width:80%; vertical-align:top; word-break:break-word; line-height:1.3; padding:10px;">
                                <b>Reglamento Interno</b><br/>
                                <b>Art. 11</b><br/>
                                La alteración o falsificación de documentos presentados por el aspirante o trabajador<br/><br/>
                                constituye falta grave que faculta al empleador a solicitar visto bueno ante el inspector del Trabajo competente:<br/><br/>
                                sin perjuicio, de la obligatoria remisión de la información y documentos a las autoridades penales que corresponda.<br/><br/>
                                <b>NOTA:</b> Toda información aquí proporcionada será tratada.
                            </td> -->

                            <td style="border:1px solid #000; width:10%; text-align:center; vertical-align:middle;">
                                <b>Fecha de solicitud</b><br/>
                                <span t-field="applicant.create_date"/>
                            </td>

                            <td style="border:1px solid #000; width:10%; text-align:center; vertical-align:middle;">
                                <t t-if="applicant.image_1920">
                                    <img t-att-src="'/web/image/hr.applicant/%s/image_1920' % applicant.id"
                                        style="width:100px; height:130px; object-fit:cover; display:block; margin:0 auto;"/>
                                </t>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Datos Personales
                            </td>
                        </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Apellido Paterno</th>
                                <th style="border:1px solid #000; font-weight:bold;">Apellido Materno</th>
                                <th style="border:1px solid #000; font-weight:bold;">Nombre(s)</th>
                                <th style="border:1px solid #000; font-weight:bold;">Edad</th>
                            </tr>
                            <tr>
                                <t t-set="nombre_completo" t-value="applicant.partner_name.split(' ')"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="nombre_completo[0]"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="nombre_completo[1]"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="' '.join(nombre_completo[2:])"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.age"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Dirección de domicilio:</th>
                                <th style="border:1px solid #000; font-weight:bold;">Parroquia</th>
                                <th style="border:1px solid #000; font-weight:bold;">Fecha de nacimiento:</th>
                                <th style="border:1px solid #000;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.address"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.parish"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.birthdate"/>
                                <td style="border:1px solid #000;"></td>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Lugar de nacimiento: Pais</th>
                                <th style="border:1px solid #000; font-weight:bold;">Provincia:</th>
                                <th style="border:1px solid #000; font-weight:bold;">Teléfono:</th>
                                <th style="border:1px solid #000; font-weight:bold;">Celular:</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.birth_country_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.provincia_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.partner_phone"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.partner_mobile"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Vive con:</th>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo de vivienda</th>
                                <th style="border:1px solid #000; font-weight:bold;">Número de hijos:</th>
                                <th style="border:1px solid #000;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.vive_con"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.tipo_vivienda"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.num_hijos"/>
                                <td style="border:1px solid #000;"></td>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Personas que dependen de usted</th>
                                <th style="border:1px solid #000; font-weight:bold;">Correo electrónico</th>
                                <th style="border:1px solid #000; font-weight:bold;"></th>
                                <th style="border:1px solid #000; font-weight:bold;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.dependientes"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.email_from"/>
                                <td style="border:1px solid #000; text-align:center;"></td>
                                <td style="border:1px solid #000; text-align:center;"></td>
                            </tr>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Datos Personales y Documentaciòn
                            </td>
                        </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo de Documento</th>
                                <th style="border:1px solid #000; font-weight:bold;">Número</th>
                                <th style="border:1px solid #000; font-weight:bold;">Nacionalidad</th>
                                <th style="border:1px solid #000;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;">
                                    <t t-esc="dict(applicant._fields['document_type'].selection).get(applicant.document_type)"/>
                                </td>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.cedula"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="applicant.nacionality"/>
                                <td style="border:1px solid #000;"></td>
                            </tr>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Información de Salud Personal
                            </td>
                        </tr>

                        <t t-foreach="applicant.medical_ids" t-as="med">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Padece actualmente alguna enfermedad persistente</th>
                                <th style="border:1px solid #000; font-weight:bold;">Toma actualmente alguna medicacion de uso continuo</th>
                                <th style="border:1px solid #000; font-weight:bold;">Padece o ha padecido alguna enfermedad laboral</th>
                                <th style="border:1px solid #000; font-weight:bold;">Ha sido sometido a alguna cirugia</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.enfermedad_persistente"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.medicacion_continua"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.enfermedad_laboral"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.detalle_cirugia_realizada"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Detalle de enfermedad persistente</th>
                                <th style="border:1px solid #000; font-weight:bold;">Detalle de medicacion de uso continuo</th>
                                <th style="border:1px solid #000; font-weight:bold;">Detalle de enfermedad laboral</th>
                                <th style="border:1px solid #000; font-weight:bold;">Detalle de cirugia</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.detalle_enfermedad_persistente"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.detalle_medicacion_continua"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.detalle_enfermedad_laboral"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.cirugia_realizada"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Tine usted alguna discapacidad</th>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo de discapacidad</th>
                                <th style="border:1px solid #000; font-weight:bold;">Porcentaje</th>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo sangre</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.discapacidad"></td>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.tipo_discapacidad"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.porcentaje_discapacidad"/> 
                                <td style="border:1px solid #000; text-align:center;" t-esc="med.tipo_sangre"/>
                            </tr>
                        </t>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Datos Familiares
                            </td>
                        </tr>

                        <t t-foreach="applicant.family_ids" t-as="fam">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Nombres completos</th>
                                <th style="border:1px solid #000; font-weight:bold;">Cédula de identidad</th>
                                <th style="border:1px solid #000; font-weight:bold;">Fecha nacimiento</th>
                                <th style="border:1px solid #000; font-weight:bold;">Teléfono</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.cedula"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.birthdate"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.phone"/>
                            </tr>
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Ocupación y Empresa</th>
                                <th style="border:1px solid #000; font-weight:bold;">Dependen economicamente de Ud.</th>
                                <th style="border:1px solid #000; font-weight:bold;">Discapacidad</th>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo de discapacidad y porcentaje</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.occupation"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.economically_dependent"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.disability"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="fam.disability_type"/>
                            </tr>
                        </t>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Formación
                            </td>
                        </tr>

                        <t t-foreach="applicant.education_ids" t-as="edu">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Nivel Educativo</th>
                                <th style="border:1px solid #000; font-weight:bold;">Institución Educativa</th>
                                <th style="border:1px solid #000; font-weight:bold;">Desde</th>
                                <th style="border:1px solid #000; font-weight:bold;">Hasta</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.level_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.institucion"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.fecha_inicio"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.year_fin"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Título Recibido</th>
                                <th style="border:1px solid #000; font-weight:bold;">País</th>
                                <th style="border:1px solid #000; font-weight:bold;">Ciudad</th>
                                <th style="border:1px solid #000; font-weight:bold;">Estudia en la actualidad</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.titulo"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.country_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.state_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" 
                                    t-esc="dict(edu._fields['study_current'].selection).get(edu.study_current)"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Tipo de formación (título a obtener)</th>
                                <th style="border:1px solid #000; font-weight:bold;">Institución</th>
                                <th style="border:1px solid #000; font-weight:bold;">Horario</th>
                                <th style="border:1px solid #000; font-weight:bold;">Carrera</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.titulo_por_obtener"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.institucion_2"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.horario"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.carrera"/>
                            </tr>

                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Nivel Actual</th>
                                <th style="border:1px solid #000; font-weight:bold;"></th>
                                <th style="border:1px solid #000; font-weight:bold;"></th>
                                <th style="border:1px solid #000; font-weight:bold;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="edu.estado"/>
                                <td style="border:1px solid #000; text-align:center;"/>
                                <td style="border:1px solid #000; text-align:center;"/>
                                <td style="border:1px solid #000; text-align:center;"/>
                            </tr>
                        </t>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Experiencia Laboral
                            </td>
                        </tr>

                        <t t-foreach="applicant.experience_job_ids" t-as="exp">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Nombre de la Compañia</th>
                                <th style="border:1px solid #000; font-weight:bold;">Cargo Desempeñado</th>
                                <th style="border:1px solid #000; font-weight:bold;">Tiempo que presto sus servicios</th>
                                <th style="border:1px solid #000; font-weight:bold;">Teléfonos</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.empresa"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.tiempo_servicio"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.telefonos"/>
                            </tr>
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Ingreso Mensual</th>
                                <th style="border:1px solid #000; font-weight:bold;">Motivo de Separaciòn</th>
                                <th style="border:1px solid #000; font-weight:bold;">Nombre de su jefe directo</th>
                                <th style="border:1px solid #000; font-weight:bold;">Cargo de su jefe directo</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.ingreso_mensual"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.motivo_separacion"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.jefe_directo"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.cargo_jefe_directo"/>
                            </tr>
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Desde</th>
                                <th style="border:1px solid #000; font-weight:bold;">Hasta</th>
                                <th style="border:1px solid #000; font-weight:bold;">País</th>
                                <th style="border:1px solid #000; font-weight:bold;">Ciudad</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.fecha_inicio"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.year_fin"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.country_id.name"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="exp.state_id.name"/>
                            </tr>
                        </t>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Posee Familiares o conocidos que trabajen para el grupo Empresarial
                            </td>
                        </tr>

                        <t t-foreach="applicant.known_ids" t-as="kn">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Posee familiares o conocidos que trabajen para el grupo empresarial</th>
                                    <th style="border:1px solid #000; font-weight:bold;">Nombre completo</th>
                                            <th style="border:1px solid #000; font-weight:bold;">Relación</th>
                                        <th style="border:1px solid #000; font-weight:bold;">Parentesco</th>
                                    </tr>
                                    <tr>
                                        <td style="border:1px solid #000; text-align:center;">
                                            <t t-esc="dict(kn._fields['posee_familiares'].selection).get(kn.posee_familiares)"/>
                                        </td>
                                    <td style="border:1px solid #000; text-align:center;" t-esc="kn.nombre_completo"/>
                                    <td style="border:1px solid #000;">
                                    <t t-esc="dict(kn._fields['relacion'].selection).get(kn.relacion)"/></td>
                                <td style="border:1px solid #000; text-align:center;" t-esc="kn.parentesco"/>
                            </tr>                        
                        </t>

                        <tr>
                            <td colspan="4" style="background:#bcdff1; border:1px solid #000; text-align:center; font-weight:bold;">
                                Referencias Personales
                            </td>
                        </tr>

                        <t t-foreach="applicant.reference_ids" t-as="ref">
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Nombre</th>
                                <th style="border:1px solid #000; font-weight:bold;">Domicilio</th>
                                <th style="border:1px solid #000; font-weight:bold;">Teléfono</th>
                                <th style="border:1px solid #000; font-weight:bold;">Ocupación</th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="ref.nombre"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="ref.domicilio"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="ref.telefono"/>
                                <td style="border:1px solid #000; text-align:center;" t-esc="ref.ocupacion"/>
                            </tr>
                            <tr>
                                <th style="border:1px solid #000; font-weight:bold;">Tiempo de conocerlo</th>
                                <th style="border:1px solid #000;"></th>
                                <th style="border:1px solid #000;"></th>
                                <th style="border:1px solid #000;"></th>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000; text-align:center;" t-esc="ref.tiempo_conocerlo"/>
                                <td style="border:1px solid #000;"></td>
                                <td style="border:1px solid #000;"></td>
                                <td style="border:1px solid #000;"></td>
                            </tr>
                        </t>

                    <tr>
                        <!-- <td colspan="3" style="border:1px solid #000; vertical-align:top; word-break:break-word; line-height:1.3; padding:10px;">
                            <b>Dejo en constancia de que la información detallada en el presente documento se apega estrictamente</b>
                            <b>a la verdad y declaro estar consciente de que la misma será verificada, tanto personal como</b>
                            <b>crediticia en cualquier momento, razón por lo que asumo la responsabilidad de la misma.</b>
                        </td> -->
                        <td colspan="3" style="border:1px solid #000; vertical-align:top; word-break:break-word; line-height:1.3; padding:10px;">
                            <t t-raw="applicant.reglamento_id.reglamento"/>
                        </td>


                        <td style="border:1px solid #000; text-align:center; vertical-align:bottom; padding:10px;">
                            <div style="margin-bottom:25px;">
                                _______________________________
                            </div>
                            <div>Firma del solicitante</div>
                            <div style="margin-top:8px;">
                                C.C.: <t t-esc="applicant.cedula"/>
                            </div>
                        </td>
                    </tr>

                    </table>

                </div> <!-- page -->

                <t t-set="footer" t-value="env['hr.footer'].search([], limit=1)"/>
                <div style="width:100%; margin-top:20px; text-align:justify; font-family:'Times New Roman', Times, serif; padding-top:5px;">
                    <t t-if="footer">
                        <span t-raw="footer.descripcion"/>
                    </t>
                </div>

            </t> <!-- foreach docs -->

        </t> <!-- layout -->

    </template>
</odoo>
